---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/navigation';
---

<BaseLayout title="Contact — Geoffrey Rugarabamu">
  <section class="page-section">
    <div class="section-container max-w-2xl">
      <h1 class="text-3xl sm:text-4xl font-serif font-bold text-espresso mb-6">Let's connect</h1>

      <p class="text-espresso/75 text-base sm:text-lg leading-relaxed mb-10">
        I'm always open to conversations about data governance, people analytics, or interesting
        problems worth solving. Whether you're building a data team, thinking through a governance
        strategy, or just want to exchange ideas — I'd love to hear from you.
      </p>

      <div class="space-y-4">
        <a
          href={`mailto:${siteConfig.email}`}
          class="card flex items-center gap-4 no-underline group"
        >
          <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-warm-gray">Email</p>
            <p class="text-espresso font-medium group-hover:text-terracotta transition-colors">{siteConfig.email}</p>
          </div>
        </a>

        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="card flex items-center gap-4 no-underline group"
        >
          <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-terracotta" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-warm-gray">LinkedIn</p>
            <p class="text-espresso font-medium group-hover:text-terracotta transition-colors">Geoffrey Rugarabamu</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
